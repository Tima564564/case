generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole { USER ADMIN RISK }
enum Rarity { COMMON RARE EPIC LEGENDARY MYTHIC }
enum InventoryStatus { OWNED SOLD UPGRADED WITHDRAWN BATTLE_LOCKED }
enum LedgerType { DEPOSIT WITHDRAWAL CASE_OPEN ITEM_SELL UPGRADE BATTLE_WIN DAILY_BONUS REFERRAL_REWARD ADMIN_ADJUSTMENT }
enum BattleStatus { WAITING RUNNING FINISHED CANCELED }
enum PaymentStatus { PENDING CONFIRMED FAILED CANCELED }
enum GiftKind { TELEGRAM_GIFT ANIMATED_GIFT SEASONAL_GIFT LIMITED_EDITION COLLECTIBLE STARS_PACK PREMIUM TON_VOUCHER }
enum GiftListingStatus { ACTIVE SOLD CANCELED EXPIRED }
enum GiftTransferStatus { PENDING ACCEPTED CANCELED FAILED }
enum EconomyEventType { CASE_OPEN RTP_REBALANCE DROP_RATE_CHANGE JACKPOT_TRIGGER RISK_FLAG PAYOUT_SPIKE }
enum TonWalletStatus { CONNECTED DISCONNECTED BLOCKED }
enum VipTier { BRONZE SILVER GOLD PLATINUM DIAMOND }

model User {
  id             String          @id @default(cuid())
  telegramId     String          @unique
  username       String?
  firstName      String?
  lastName       String?
  avatarUrl      String?
  locale         String          @default("en")
  role           UserRole        @default(USER)
  riskScore      Int             @default(0)
  vipTier        VipTier         @default(BRONZE)
  vipXp          Int             @default(0)
  depositVolume  Decimal         @default(0) @db.Decimal(18, 6)
  referralCode   String          @unique @default(cuid())
  referredById   String?
  referredBy     User?           @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]          @relation("UserReferrals")
  wallet         Wallet?
  ledgerEntries  WalletLedger[]
  inventory      InventoryItem[]
  fairRounds     FairRound[]
  upgrades       UpgradeAttempt[]
  battlePlayers  BattlePlayer[]
  createdBattles Battle[]        @relation("BattleCreator")
  dailyRewards   DailyReward[]
  taskProgress   TaskProgress[]
  payments       CryptoPayment[]
  giftTransfersSent GiftTransfer[] @relation("GiftTransferSender")
  giftTransfersReceived GiftTransfer[] @relation("GiftTransferReceiver")
  marketplaceListings GiftListing[] @relation("GiftListingSeller")
  marketplacePurchases GiftListing[] @relation("GiftListingBuyer")
  riskEvents     RiskEvent[]
  tonWallets     TonWallet[]
  starsPayments  StarsPayment[]
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  balance       Decimal  @db.Decimal(18, 6)
  lockedBalance Decimal  @db.Decimal(18, 6)
  updatedAt     DateTime @updatedAt
}

model WalletLedger {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  type      LedgerType
  amount    Decimal    @db.Decimal(18, 6)
  currency  String
  externalId String?
  metadata  Json?
  createdAt DateTime   @default(now())
  @@index([userId, createdAt])
}

model Case {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  imageUrl    String?
  price       Decimal      @db.Decimal(18, 6)
  currency    String       @default("USD")
  priceStars  Int?
  targetRtp   Decimal      @default(0.92) @db.Decimal(8, 6)
  houseEdge   Decimal      @default(0.08) @db.Decimal(8, 6)
  profitabilityTarget Decimal @default(0.08) @db.Decimal(8, 6)
  dynamicDropRates Boolean @default(false)
  seasonalEventId String?
  seasonalEvent SeasonalEvent? @relation(fields: [seasonalEventId], references: [id])
  limitedUntil DateTime?
  totalOpened  Int          @default(0)
  totalRevenue Decimal      @default(0) @db.Decimal(18, 6)
  totalPayout  Decimal      @default(0) @db.Decimal(18, 6)
  profit       Decimal      @default(0) @db.Decimal(18, 6)
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  drops       CaseDrop[]
  battleRounds BattleRound[]
  fairRounds  FairRound[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Item {
  id              String          @id @default(cuid())
  sku             String          @unique
  name            String
  imageUrl        String?
  rarity          Rarity
  value           Decimal         @db.Decimal(18, 6)
  sellPrice       Decimal         @db.Decimal(18, 6)
  giftKind        GiftKind        @default(TELEGRAM_GIFT)
  isAnimated      Boolean         @default(false)
  isSeasonal      Boolean         @default(false)
  isLimited       Boolean         @default(false)
  editionSize     Int?
  serialStart     Int?
  metadata        Json?
  fusionRecipe    Json?
  isWithdrawable  Boolean         @default(false)
  drops           CaseDrop[]
  inventoryItems  InventoryItem[]
  upgradeTargets  UpgradeAttempt[] @relation("UpgradeTarget")
  marketplaceListings GiftListing[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model CaseDrop {
  id        String  @id @default(cuid())
  caseId    String
  case      Case    @relation(fields: [caseId], references: [id])
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id])
  weight    Int
  baseWeight Int    @default(0)
  dynamicWeight Int?
  chanceBps Int?
  minRoll   Int?
  maxRoll   Int?
  createdAt DateTime @default(now())
  @@index([caseId])
}

model InventoryItem {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  itemId      String
  item        Item            @relation(fields: [itemId], references: [id])
  status      InventoryStatus @default(OWNED)
  source      String
  serialNo    Int?
  lockedUntil DateTime?
  fairRoundId String?
  fairRound   FairRound?      @relation(fields: [fairRoundId], references: [id])
  outgoingTransfers GiftTransfer[] @relation("GiftTransferInventory")
  listings    GiftListing[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([userId, status])
}

model UpgradeAttempt {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  sourceInventoryItemId String
  targetItemId          String
  targetItem            Item     @relation("UpgradeTarget", fields: [targetItemId], references: [id])
  successChance         Decimal  @db.Decimal(8, 6)
  success               Boolean
  fairRoundId           String?
  fairRound             FairRound? @relation(fields: [fairRoundId], references: [id])
  createdAt             DateTime @default(now())
}

model FairRound {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  caseId         String?
  case           Case?           @relation(fields: [caseId], references: [id])
  serverSeedHash String
  serverSeed     String?
  clientSeed     String
  nonce          Int
  revealedAt     DateTime?
  inventoryItems InventoryItem[]
  upgradeAttempts UpgradeAttempt[]
  createdAt      DateTime        @default(now())
}

model Battle {
  id           String         @id @default(cuid())
  creatorId    String
  creator      User           @relation("BattleCreator", fields: [creatorId], references: [id])
  mode         String
  status       BattleStatus   @default(WAITING)
  entryCaseIds String[]
  players      BattlePlayer[]
  rounds       BattleRound[]
  winnerId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model BattlePlayer {
  id        String   @id @default(cuid())
  battleId  String
  battle    Battle   @relation(fields: [battleId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  seat      Int
  totalWin  Decimal  @default(0) @db.Decimal(18, 6)
  joinedAt  DateTime @default(now())
  @@unique([battleId, userId])
}

model BattleRound {
  id        String   @id @default(cuid())
  battleId  String
  battle    Battle   @relation(fields: [battleId], references: [id])
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  roundNo   Int
  result    Json?
  createdAt DateTime @default(now())
}

model DailyReward {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dayKey    String
  amount    Decimal  @db.Decimal(18, 6)
  claimedAt DateTime @default(now())
  @@unique([userId, dayKey])
}

model Task {
  id          String         @id @default(cuid())
  code        String         @unique
  title       Json
  reward      Decimal        @db.Decimal(18, 6)
  isActive    Boolean        @default(true)
  progress    TaskProgress[]
  createdAt   DateTime       @default(now())
}

model TaskProgress {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  value     Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  @@unique([taskId, userId])
}

model CryptoPayment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  provider      String
  chain         String
  asset         String
  address       String?
  txHash        String?
  amount        Decimal       @db.Decimal(24, 10)
  fiatValue     Decimal?      @db.Decimal(18, 6)
  status        PaymentStatus @default(PENDING)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([userId, status])
  @@index([txHash])
}

model TonWallet { id String @id @default(cuid()) userId String user User @relation(fields: [userId], references: [id]) address String network String @default("mainnet") status TonWalletStatus @default(CONNECTED) proof Json? lastUsedAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@unique([userId, address]) @@index([address]) }
model StarsPayment { id String @id @default(cuid()) userId String user User @relation(fields: [userId], references: [id]) invoicePayload String @unique telegramPaymentChargeId String? amountStars Int balanceAmount Decimal @db.Decimal(18, 6) status PaymentStatus @default(PENDING) metadata Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@index([userId, status]) }
model GiftTransfer { id String @id @default(cuid()) senderId String sender User @relation("GiftTransferSender", fields: [senderId], references: [id]) receiverId String? receiver User? @relation("GiftTransferReceiver", fields: [receiverId], references: [id]) receiverTelegramId String? inventoryItemId String inventoryItem InventoryItem @relation("GiftTransferInventory", fields: [inventoryItemId], references: [id]) status GiftTransferStatus @default(PENDING) message String? acceptedAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@index([senderId, createdAt]) @@index([receiverId, status]) }
model GiftListing { id String @id @default(cuid()) sellerId String seller User @relation("GiftListingSeller", fields: [sellerId], references: [id]) buyerId String? buyer User? @relation("GiftListingBuyer", fields: [buyerId], references: [id]) inventoryItemId String inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id]) itemId String item Item @relation(fields: [itemId], references: [id]) price Decimal @db.Decimal(18, 6) currency String @default("USD") status GiftListingStatus @default(ACTIVE) expiresAt DateTime? soldAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@index([status, createdAt]) @@index([sellerId, status]) }
model FusionAttempt { id String @id @default(cuid()) userId String sourceInventoryItemIds String[] targetItemId String? successChance Decimal @db.Decimal(8, 6) success Boolean fairRoundId String? metadata Json? createdAt DateTime @default(now()) @@index([userId, createdAt]) }
model SeasonalEvent { id String @id @default(cuid()) slug String @unique title String startsAt DateTime endsAt DateTime boostConfig Json? isActive Boolean @default(true) cases Case[] createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model EconomySnapshot { id String @id @default(cuid()) caseId String? caseSlug String? eventType EconomyEventType openings Int @default(0) revenue Decimal @default(0) @db.Decimal(18, 6) payout Decimal @default(0) @db.Decimal(18, 6) profit Decimal @default(0) @db.Decimal(18, 6) actualRtp Decimal @default(0) @db.Decimal(8, 6) targetRtp Decimal @default(0) @db.Decimal(8, 6) houseEdge Decimal @default(0) @db.Decimal(8, 6) metadata Json? createdAt DateTime @default(now()) @@index([caseId, createdAt]) @@index([eventType, createdAt]) }
model RiskEvent { id String @id @default(cuid()) userId String? user User? @relation(fields: [userId], references: [id]) severity String type String score Int metadata Json? resolved Boolean @default(false) createdAt DateTime @default(now()) @@index([userId, createdAt]) @@index([severity, resolved]) }
model JackpotEvent { id String @id @default(cuid()) slug String @unique title String poolAmount Decimal @db.Decimal(18, 6) currency String @default("USD") triggerRule Json startsAt DateTime endsAt DateTime isActive Boolean @default(true) winnerId String? paidAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model AdminAuditLog { id String @id @default(cuid()) adminId String action String target String payload Json? createdAt DateTime @default(now()) }
